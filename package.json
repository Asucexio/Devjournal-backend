{
  "name": "devjournal-backend",
  "version": "1.0.0",
  "description": "Backend for DevJournal using Express + Supabase",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "webhook:set": "ts-node src/scripts/setWebhook.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
